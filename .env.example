# Phase 1 inventory root directory
PDFZX_PDF_ROOT=./pdf_root

# Registry JSON output path
PDFZX_JSON_DB=./db.json

# Future relational DB path for Phase 2 online workflows.
# Intended logic:
# - if PDFZX_ONLINE_FEATURES=false, Phase 1 can continue using PDFZX_JSON_DB only
# - if PDFZX_ONLINE_FEATURES=true, SQLite storage is required for prompt/suggestion CRUD
# - default target is ./db.sqlite3
PDFZX_SQLITE3_DB_PATH=./db.sqlite3

# Minimum extracted character count to classify a PDF as digital
PDFZX_OCR_CHAR_THRESHOLD=100

# Number of leading pages to inspect for digital/scanned detection
PDFZX_OCR_SCAN_PAGES=3

# Deterministic document-name normalization in Phase 1
PDFZX_ENABLE_NAME_NORMALIZATION=true

# Client logging level
PDFZX_LOG_LEVEL=DEBUG

# Parallel worker processes for PDF extraction (1 = serial, 0 = auto CPU count)
PDFZX_WORKERS=1

# Yazi chooser output file used by Textual/CLI clients
PDFZX_CHOICE_FILE=./yazi-choice.txt

# Textual app internal debug breadcrumb log
PDFZX_TEXTUAL_DEBUG_LOG=/tmp/textual_cli.log

# Textual app mirrored stdlib/pdfzx log file
PDFZX_TEXTUAL_APP_LOG=/tmp/textual_cli.app.log

# Override the client script or working directory for Textual subprocess execution
PDFZX_CLIENT_SCRIPT=./client.py
PDFZX_CLIENT_CWD=.

# Phase 2.1 — full-text extraction output directory
PDFZX_FULLTEXT_DIR=./pdf_fulltext

# Phase 2.1 — enable/disable text extraction (true/false)
PDFZX_EXTRACT_TEXT=true

# Enable online/LLM workflows; Phase 1 stays usable with this disabled.
# Intended logic:
# - false: no API key required, no online calls, no SQLite workflow required
# - true: online/LLM workflow enabled, OpenAI config is required, SQLite DB is expected
PDFZX_ONLINE_FEATURES=false

# OpenAI settings for online suggestion workflows.
# These are only relevant when PDFZX_ONLINE_FEATURES=true.
PDFZX_OPENAI_API_KEY=
PDFZX_OPENAI_MODEL=gpt-4o-mini

# Limit ToC entries sent into LLM prompts that use ToC evidence.
PDFZX_LLM_MAX_TOC_ENTRIES=30

# Stable seed for deterministic taxonomy-partition batching order.
PDFZX_PARTITION_SEED=pdfzx-partition-v1

# Fixed batch size for taxonomy-partition chunking.
PDFZX_PARTITION_CHUNK_SIZE=50
